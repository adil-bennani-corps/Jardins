  "typography": {
    "fontFamily": {
      "heading": ["Playfair Display", "Georgia", "Times New Roman", "serif"],
      "body":    ["Inter", "system-ui", "-apple-system", "sans-serif"],
      "mono":    ["JetBrains Mono", "Consolas", "monospace"]
    },
    "scale": {
      "description": "9-step type scale — ratio 1.250 (Major Third)",
      "xs":   { "size": "0.75rem",  "lineHeight": "1rem",   "letterSpacing": "0.01em"  },
      "sm":   { "size": "0.875rem", "lineHeight": "1.25rem", "letterSpacing": "0.005em" },
      "base": { "size": "1rem",     "lineHeight": "1.625rem", "letterSpacing": "0" },
      "lg":   { "size": "1.125rem", "lineHeight": "1.75rem", "letterSpacing": "-0.005em" },
      "xl":   { "size": "1.25rem",  "lineHeight": "1.875rem", "letterSpacing": "-0.01em" },
      "2xl":  { "size": "1.5rem",   "lineHeight": "2rem",   "letterSpacing": "-0.015em" },
      "3xl":  { "size": "2rem",     "lineHeight": "2.5rem", "letterSpacing": "-0.02em" },
      "4xl":  { "size": "2.5rem",   "lineHeight": "3rem",   "letterSpacing": "-0.025em" },
      "5xl":  { "size": "3.25rem",  "lineHeight": "3.75rem", "letterSpacing": "-0.03em" }
    },
    "fontWeight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "description": "8px grid — Breathable Luxury spacing",
    "unit": 8,
    "scale": {
      "0":  "0px",
      "1":  "4px",
      "2":  "8px",
      "3":  "12px",
      "4":  "16px",
      "5":  "20px",
